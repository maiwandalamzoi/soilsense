# Copy this file to .streamlit/secrets.toml and fill in values.
# NEVER commit secrets.toml to git.

# Google Earth Engine service account
# 1. Create a service account at console.cloud.google.com
# 2. Enable Earth Engine API for the project
# 3. Register the service account at https://signup.earthengine.google.com/#!/service_accounts
# 4. Download the JSON key and paste its contents here as a single-line string

GEE_SERVICE_ACCOUNT_EMAIL = "your-sa@your-project.iam.gserviceaccount.com"
GEE_SERVICE_ACCOUNT_JSON = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}
"""
